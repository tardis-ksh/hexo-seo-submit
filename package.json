{
  "name": "hexo-seo-submit",
  "version": "1.8.1",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "prepare": "husky",
    "format": "prettier --write 'src/**/*.{ts,js,json,md}'",
    "lint": "eslint"
  },
  "bin": {
    "hexo-seo-submit": "bin/hexo-seo-submit.mjs"
  },
  "files": [
    "dist/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tardis-ksh/hexo-seo-submit.git"
  },
  "keywords": [
    "hexo",
    "seo",
    "deployer",
    "google",
    "baidu",
    "bing",
    "CI",
    "auto push",
    "github",
    "coding",
    "jenkins"
  ],
  "author": "tardis <kshao666@gmail.com> (https://ksh7.com)",
  "license": "MIT",
  "description": "Manual or automatic submit your site to search engines(google, bing, baidu). There are Github actions and coding jenkins available for CI",
  "packageManager": "pnpm@11.9.0",
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@types/hexo": "^7.0.0",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^26.0.0",
    "@typescript-eslint/parser": "^8.62.0",
    "cpx2": "^9.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "lint-staged": {
    "src/*.{ts,js,json,md}": [
      "pnpm run format",
      "pnpm run lint"
    ]
  },
  "peerDependencies": {
    "hexo": ">=7",
    "lodash.merge": ">=4",
    "chalk": "5",
    "axios": ">=1.10",
    "https-proxy-agent": "9"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "google-auth-library": "^10.7.0",
    "handlebars": "^4.7.9",
    "wildcard-match": "^5.1.4"
  }
}
